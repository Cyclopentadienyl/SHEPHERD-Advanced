# ============================================
# SHEPHERD-Advanced .gitignore
# ============================================

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.dll

# --- Virtual env ---
.venv/
env/
venv/

# --- Packaging / build ---
build/
dist/
*.egg-info/
pip-wheel-metadata/

# --- Logs and reports (keep directories) ---
logs/*
!logs/.gitkeep

reports/*
!reports/.gitkeep

# --- Data ---
# Raw data - track config, ignore large datasets
data/raw/**/*.obo
data/raw/**/*.owl
data/raw/**/*.json.gz
data/raw/**/*.csv.gz

# Workspaces - all generated files ignored, keep structure marker
data/workspaces/**/*.pt
data/workspaces/**/*.pkl
data/workspaces/**/*.npy
data/workspaces/**/*.json
data/workspaces/**/checkpoints/
!data/workspaces/.gitkeep

# Legacy processed/ (remove once fully migrated)
data/processed/

# External data - ignore contents, keep README
data/external/*
!data/external/.gitignore
!data/external/README.md

# Cache
data/cache/

# --- Models ---
# Only pretrained/ survives (KG-independent base models)
# checkpoints/, experiments/, production/ are now inside workspaces
models/pretrained/**/*
!models/pretrained/README.md

# --- Generated configs (hardware-specific, regenerated by deploy scripts) ---
configs/platform.yaml

# --- Temp files ---
*.tmp
*.log

# --- OS / IDE ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# --- Coverage / test ---
.coverage
htmlcov/
.tox/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- Environment files (敏感資訊) ---
.env
.env.local
*.key
*.pem


# ============================================
# Advanced: CI/CD, HPC, and Training
# ============================================

# --- CI/CD artifacts ---
.github/workflows/*.log
.github/workflows/__pycache__/

# --- HPC / Cluster job logs ---
slurm-*.out          # SLURM
slurm-*.err
*.o[0-9]*            # PBS/Torque output
*.e[0-9]*            # PBS/Torque error
*.pe[0-9]*           # Grid Engine
*.po[0-9]*           # Grid Engine

# --- Training artifacts (prevent accidental commits) ---
wandb/               # Weights & Biases
.neptune/            # Neptune.ai
mlruns/              # MLflow
tensorboard/         # TensorBoard logs
lightning_logs/      # PyTorch Lightning

# --- Profiling / debugging ---
*.prof               # Python profiler
*.nsys-rep           # NVIDIA Nsight
*.nvvp               # NVIDIA Visual Profiler
*.qdrep              # NVIDIA Nsight Compute
*.ncu-rep            # NVIDIA Nsight Compute (new)

# --- ARM-specific (DGX Spark) ---
*.arm64.log
*_arm_debug.txt

# --- UI config files (user-specific, not tracked) ---
.shepherd_ui_config.json
.shepherd_training_config.json
.workspace_restructure_blueprint.md
